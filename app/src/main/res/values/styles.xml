<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="FitPalChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipCornerRadius">50dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>

        <!-- Colores por estado -->
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="rippleColor">@color/chip_ripple_selector</item>

        <!-- Quita el iconito de “check”  -->
        <item name="checkedIconVisible">false</item>
    </style>
</resources>