<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="36dp"
    android:paddingBottom="24dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Administrar Perfil"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:paddingBottom="20dp"/>

    <!-- Foto de perfil -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_profile_photo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center_horizontal"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person"
        app:shapeAppearanceOverlay="@style/ShapeCircle"
        app:strokeColor="@color/primary"
        app:strokeWidth="3dp"
        android:padding="5dp"/>

    <!-- Nombre de usuario -->
    <TextView
        android:id="@+id/tv_username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre de Usuario"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingTop="15dp"/>

    <!-- Email de usuario -->
    <TextView
        android:id="@+id/tv_user_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="correo@ejemplo.com"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Espacio -->
    <View
        android:layout_width="match_parent"
        android:layout_height="22dp" />

    <!-- Botón actualizar foto -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_update_photo"
        android:layout_gravity="center_horizontal"
        android:layout_width="250dp"
        android:layout_height="56dp"
        android:letterSpacing="0.12"
        android:text="Actualizar Foto"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp" />

    <!-- Para empujar el logout hasta abajo -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Botón cerrar sesión -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:letterSpacing="0.12"
        android:text="Cerrar Sesion"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp" />

</LinearLayout>